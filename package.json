{
  "name": "drop-landing",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev":        "vite --port 5173",
    "dev:server": "node --watch server/index.js",
    "dev:all":    "concurrently -n FRONT,API -c cyan,magenta \"npm run dev\" \"npm run dev:server\"",
    "build":      "vite build",
    "start":      "node server/index.js",
    "preview":    "vite preview"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "i18next": "^26.1.0",
    "jsonwebtoken": "^9.0.3",
    "pdfkit": "^0.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.7",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.10"
  }
}
